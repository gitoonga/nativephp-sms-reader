{
    "name": "atendwa/nativephp-sms-reader",
    "description": "A NativePHP Mobile plugin that lets your Android app read SMS messages from the device inbox and listen for incoming SMS in real time.",
    "type": "nativephp-plugin",
    "license": "MIT",
    "keywords": ["nativephp", "sms", "android", "mobile", "plugin", "laravel"],
    "homepage": "https://github.com/atendwa/nativephp-sms-reader",
    "authors": [
        {
            "name": "Anthony Tendwa",
            "email": "opensource@tendwa.dev",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "opensource@tendwa.dev",
        "issues": "https://github.com/atendwa/nativephp-sms-reader/issues",
        "source": "https://github.com/atendwa/nativephp-sms-reader"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "laravel/boost": "^2.2",
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Atendwa\\SmsReader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atendwa\\SmsReader\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Atendwa\\SmsReader\\SmsReaderServiceProvider"
            ],
            "aliases": {
                "SmsReader": "Atendwa\\SmsReader\\Facades\\SmsReader"
            }
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
